# ===== 阿里云 OSS 本地直传配置 =====
# 复制本文件为 .env 后填写。建议用「RAM 子账号」且只授权这一个 Bucket。
# .env 已被 .gitignore 忽略，不会提交。切勿把密钥发给任何人/前端。

# RAM 子账号 AccessKey（必填）
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# Bucket 名称（必填），如 my-app-upload
OSS_BUCKET=

# 地域（必填），如 oss-cn-hangzhou / oss-cn-shanghai
OSS_REGION=oss-cn-hangzhou

# 上传目录前缀（可选）
OSS_DIR=uploads/

# Bucket 是否公共读：公共读 true（回显直接拼 URL）；私有 false（回显走签名 GET）
OSS_PUBLIC_READ=true

# 本地签名服务端口（可选）
PORT=5180
